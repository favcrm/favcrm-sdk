{
  "name": "@favcrm/sdk",
  "version": "0.2.4",
  "description": "FavCRM SDK - Shared business logic for shop, checkout, and promotions",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "browser": "./dist/favcrm-sdk.iife.js",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./browser": {
      "import": "./dist/favcrm-sdk.js",
      "script": "./dist/favcrm-sdk.iife.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsgo",
    "build:lib": "vite build --config vite.config.lib.ts",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "type-check": "tsgo --noEmit",
    "lint": "eslint src"
  },
  "keywords": [
    "favcrm",
    "sdk",
    "shop",
    "checkout",
    "promotions"
  ],
  "author": "FavCRM Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/favcrm/favcrm-sdk"
  },
  "packageManager": "pnpm@10.28.2",
  "devDependencies": {
    "@typescript/native-preview": "^7.0.0-dev",
    "@vitest/coverage-v8": "^2.1.9",
    "vite": "^6.0.0",
    "vitest": "^2.1.9"
  }
}
